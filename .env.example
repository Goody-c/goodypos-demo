# Copy this file to .env and replace the placeholder values before deployment.
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
JWT_SECRET=replace-with-a-long-random-secret-generated-via-openssl-or-node
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Optional: keep business data outside the app folder for safer backups and antivirus exclusions
GOODY_POS_APP_DIR=
GOODY_POS_DATA_DIR=

# PostgreSQL-only runtime (required verified mode)
# 1) set GOODY_POS_POSTGRES_URL / DATABASE_URL
# 2) run `npm run db:postgres:bootstrap`
# 3) build with `npm run build && npm run build:server`
# 4) start the production app with `npm start`
GOODY_POS_DB_PROVIDER=postgres
GOODY_POS_POSTGRES_URL=postgresql://postgres:replace-me@your-host:5432/goodypos
GOODY_POS_POSTGRES_SSL=true
GOODY_POS_ENABLE_PG_READS=true
GOODY_POS_ENABLE_PG_MIRROR_WRITES=false
DATABASE_URL=postgresql://postgres:replace-me@your-host:5432/goodypos

# Optional: publish a remote update feed so older installs can detect new versions automatically
GOODY_POS_PUBLIC_UPDATE_BASE_URL=
GOODY_POS_UPDATE_MANIFEST_URL=

# Optional licensing integration for new store activation
GOODY_POS_LICENSE_API_URL=https://goodypos1.vercel.app
GOODY_POS_LICENSE_REQUIRED_FOR_NEW_STORES=true

# Optional automation credentials for deeper checks
SMOKE_USERNAME=
SMOKE_PASSWORD=
E2E_USERNAME=
E2E_PASSWORD=
SMOKE_BASE_URL=http://localhost:3000
E2E_BASE_URL=http://localhost:3000

# Emergency recovery — click logo 5x on login screen to trigger
GOODY_POS_RECOVERY_CODE=6244059559
