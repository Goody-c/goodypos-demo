{
  "name": "goody-pos",
  "private": true,
  "version": "1.6.0",
  "description": "Goody POS web point-of-sale application",
  "author": "Goody POS",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-preflight.mjs && tsx server.ts",
    "dev:raw": "tsx server.ts",
    "start": "node server.mjs",
    "build": "vite build",
    "vercel-build": "vite build && esbuild api/index.ts --bundle --platform=node --format=esm --packages=external --outfile=api/handler.mjs --external:sql.js --external:bcryptjs --external:jsonwebtoken --external:pg --external:dotenv --external:sharp --external:multer",
    "build:server": "esbuild server.ts --bundle --platform=node --format=esm --packages=external --outfile=server.mjs",
    "preview": "vite preview",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('server.mjs',{force:true});\"",
    "lint": "tsc --noEmit",
    "smoke": "node scripts/smoke-check.mjs",
    "db:postgres:test": "node scripts/test-postgres-connection.mjs",
    "db:postgres:init": "node scripts/init-postgres-schema.mjs",
    "db:postgres:sync-core": "node scripts/sync-local-core-to-postgres.mjs",
    "db:postgres:bootstrap": "npm run db:postgres:test && npm run db:postgres:init && npm run db:postgres:sync-core",
    "audit": "npm run lint && npm run build && npm run smoke",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "test:api-rules": "tsx tests/api-rules.vendor-payables.test.ts",
    "audit:full": "npm run audit && npm run e2e",
    "release": "node scripts/build-release.mjs mac",
    "release:mac": "node scripts/build-release.mjs mac",
    "release:windows": "node scripts/build-release.mjs windows",
    "release:all": "node scripts/build-release.mjs all"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "goody-db-driver": "file:./shims/goody-db-driver",
    "jsbarcode": "^3.12.3",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.2",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "esbuild": "^0.25.3",
    "pkg": "^5.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
